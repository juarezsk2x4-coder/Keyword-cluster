# Turso (libSQL) connection for production.
# When TURSO_DATABASE_URL is unset, the app falls back to a local SQLite file
# at ./data/app.db (only works on a machine with persistent disk — NOT on Vercel).
#
# To set up Turso (free):
#   1. Sign up at https://turso.tech (GitHub login).
#   2. Create a database (1 click).
#   3. Click "Show credentials" -> copy the URL and Auth Token.
#   4. Paste them into Vercel's "Environment Variables" page (Settings > Environment Variables).
#   5. Redeploy. The schema auto-creates on first request.

TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJhbG...your-long-token...
